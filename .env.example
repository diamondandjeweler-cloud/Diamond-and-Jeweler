# BoLe — Environment Variables (example)
# Copy to .env.local and fill in. Never commit real values.

# ---------- Supabase ----------
# From Supabase dashboard → Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR...

# ---------- Frontend (Vite) ----------
# Same values as above, exposed to the browser bundle.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR...
VITE_SITE_URL=http://localhost:3000

# ---------- Resend (transactional email) ----------
# From https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
# During DNS propagation use 'noreply@resend.dev'; switch to 'noreply@diamondandjeweler.com' after verification.
RESEND_FROM=noreply@resend.dev

# ---------- Edge Function runtime ----------
# Only used inside Supabase Edge Functions.
EDGE_ENV=development
