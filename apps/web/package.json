{
  "name": "bole-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "prepare": "cd ../.. && npx lefthook install || exit 0",
    "dev": "vite",
    "build": "tsc --noEmit && vite build && node scripts/check-vendor-chunk.mjs && node scripts/inject-meta.mjs && node scripts/upload-sourcemaps.mjs && node scripts/strip-sourcemaps.mjs",
    "build:check": "vite build && node scripts/check-vendor-chunk.mjs",
    "preview": "vite preview --port 3000",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:seeded": "playwright test --config playwright.seeded.config.ts",
    "test:e2e:ui": "playwright test --ui",
    "types:gen:local": "supabase gen types typescript --local > src/types/db.generated.ts",
    "types:gen:remote": "supabase gen types typescript --project-id \"$SUPABASE_PROJECT_ID\" > src/types/db.generated.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-radio-group": "^1.4.3",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@sentry/react": "^10.51.0",
    "@supabase/supabase-js": "^2.110.1",
    "@vercel/og": "^0.11.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.11",
    "i18next": "^23.16.8",
    "i18next-browser-languagedetector": "^7.2.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^14.1.3",
    "react-router-dom": "^6.26.0",
    "swr": "^2.4.2",
    "tailwind-merge": "^2.5.2",
    "tailwind-variants": "^0.2.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.47.0",
    "@storybook/addon-a11y": "^8.2.9",
    "@storybook/addon-essentials": "^8.2.9",
    "@storybook/addon-interactions": "^8.2.9",
    "@storybook/react": "^8.2.9",
    "@storybook/react-vite": "^8.2.9",
    "@storybook/test": "^8.2.9",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/ui": "^2.0.5",
    "autoprefixer": "^10.4.19",
    "eslint": "^10.6.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-storybook": "^0.12.0",
    "globals": "^17.7.0",
    "jsdom": "^24.1.1",
    "lefthook": "^2.1.6",
    "postcss": "^8.4.41",
    "prettier": "^3.3.3",
    "storybook": "^8.2.9",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.63.0",
    "vite": "^5.4.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^2.0.5",
    "workbox-window": "^7.4.1"
  },
  "overrides": {
    "eslint-plugin-jsx-a11y": {
      "eslint": "$eslint"
    }
  }
}
