# ── Supabase ──────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR...

# ── Site ──────────────────────────────────────────────────────────────────────
VITE_SITE_URL=http://localhost:3000

# ── Testing flags ─────────────────────────────────────────────────────────────
# Set to "true" in dev/.env.local or CI to bypass MFA for @dnj-test.my admin
# accounts. Must be unset (or "false") in production — MFA is always enforced
# for real admin accounts regardless of this flag.
# VITE_BYPASS_ADMIN_MFA=true

# ── Sentry (error monitoring) ─────────────────────────────────────────────────
# Get from: https://sentry.io → New Project → React → DSN
# Optional — omit to disable Sentry (errors still shown in console)
VITE_SENTRY_DSN=https://xxxxx@o0.ingest.sentry.io/0

# ── Cloudflare Turnstile (bot protection) ─────────────────────────────────────
# Get from: https://dash.cloudflare.com → Turnstile → Add Site
# REQUIRED in production — without this all sign-ups bypass bot protection
VITE_TURNSTILE_SITE_KEY=0x4AAAAAAA...

# ── Edge rate-limit shared store (OPTIONAL) ──────────────────────────────────
# apps/web/middleware.ts rate-limits /api/* per IP. By default it uses an
# in-memory Map that is PER EDGE ISOLATE — under horizontal scaling each isolate
# counts independently, so the global limit is effectively multiplied.
# Set BOTH of these (REST URL + token) to back the limiter with a shared Upstash
# Redis / Vercel KV store so the limit is enforced globally across all isolates.
# Leave them UNSET to keep the current in-memory behaviour (the limiter falls
# back automatically; a store outage also fails open to the in-memory path).
#   Provision: Vercel Dashboard → Storage → Upstash Redis (or KV). The
#   integration injects these automatically. KV exposes them as KV_REST_API_URL
#   / KV_REST_API_TOKEN; Upstash as UPSTASH_REDIS_REST_URL / *_TOKEN. Both
#   name pairs are accepted.
# UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
# UPSTASH_REDIS_REST_TOKEN=...

# ── Supabase Edge Function secrets (set via: supabase secrets set KEY=value) ──
# These are NOT exposed to the frontend. Set them in Supabase project secrets.

# Resend (email delivery) — https://resend.com/api-keys
RESEND_API_KEY=re_...
# Resend webhook secret — Resend Dashboard → Webhooks → Signing Secret
RESEND_WEBHOOK_SECRET=whsec_...

# Billplz (payments) — https://www.billplz.com/enterprise/developer
# BILLPLZ_BASE_URL: production URL. For staging/testing, override to sandbox:
#   supabase secrets set BILLPLZ_BASE_URL=https://www.billplz-sandbox.com
# WARNING: the sandbox URL is intentionally NOT the default here — a copy-paste
# to production with the sandbox URL still set would route real payments to sandbox.
BILLPLZ_BASE_URL=https://www.billplz.com
BILLPLZ_API_KEY=...
BILLPLZ_COLLECTION_ID=...

# Anthropic (AI matching & BaZi scoring)
ANTHROPIC_API_KEY=sk-ant-...

# Groq (LLM fallback)
GROQ_API_KEY=gsk_...

# Daily.co (video calls) — https://dashboard.daily.co/developers
DAILY_API_KEY=...

# WATI (WhatsApp notifications) — https://app.wati.io/settings/api-access
WATI_API_KEY=...
WATI_API_URL=https://live-mt-server.wati.io/YOUR-INSTANCE
