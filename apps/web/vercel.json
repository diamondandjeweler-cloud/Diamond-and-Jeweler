{
  "routes": [
    {
      "src": "/(.*)",
      "has": [{ "type": "host", "value": "www.diamondandjeweler.com" }],
      "dest": "https://diamondandjeweler.com/$1",
      "status": 301
    },
    {
      "src": "^/job-vacancy/?$",
      "dest": "/careers",
      "status": 301
    },
    {
      "src": "/(.*)",
      "headers": {
        "X-Content-Type-Options":       "nosniff",
        "X-Frame-Options":              "DENY",
        "Referrer-Policy":              "strict-origin-when-cross-origin",
        "Strict-Transport-Security":    "max-age=63072000; includeSubDomains; preload",
        "Cross-Origin-Opener-Policy":   "same-origin-allow-popups",
        "Cross-Origin-Resource-Policy": "same-site",
        "Access-Control-Allow-Origin":  "https://diamondandjeweler.com",
        "Vary":                         "Origin",
        "Permissions-Policy":           "camera=(), microphone=(), geolocation=(), payment=(), usb=(), serial=(), magnetometer=(), gyroscope=(), accelerometer=(), midi=(), bluetooth=(), display-capture=(), publickey-credentials-get=(self), interest-cohort=(), browsing-topics=(), fullscreen=(self)",
        "Content-Security-Policy":      "default-src 'self'; script-src 'self' 'sha256-S46PoNSIlqlHWn5jWqs3zz9yXx6Zq5efyOQb01rgaLs=' https://challenges.cloudflare.com https://plausible.io; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://sfnrpbsdscikpmbhrzub.supabase.co wss://sfnrpbsdscikpmbhrzub.supabase.co https://accounts.google.com https://challenges.cloudflare.com https://plausible.io; frame-src 'self' https://accounts.google.com https://challenges.cloudflare.com; form-action 'self' https://accounts.google.com; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; upgrade-insecure-requests"
      },
      "continue": true
    },
    {
      "src": "/(?:admin|talent|hm|hr|onboarding|mfa|consent|home|referrals|points|consult|data-requests|feedback|payment)(.*)",
      "headers": {
        "X-Robots-Tag": "noindex, nofollow",
        "Cache-Control": "no-store, no-cache, must-revalidate, private",
        "Pragma": "no-cache"
      },
      "continue": true
    },
    {
      "src": "/(.*)",
      "headers": {
        "Cache-Control": "public, max-age=0, s-maxage=60, stale-while-revalidate=86400"
      },
      "continue": true
    },
    {
      "src": "/sitemap\\.xml",
      "headers": {
        "Content-Type":  "application/xml; charset=utf-8",
        "Cache-Control": "public, max-age=3600"
      },
      "continue": true
    },
    {
      "src": "/robots\\.txt",
      "headers": {
        "Content-Type":  "text/plain; charset=utf-8",
        "Cache-Control": "public, max-age=3600"
      },
      "continue": true
    },
    {
      "src": "/\\.well-known/security\\.txt",
      "headers": {
        "Content-Type":  "text/plain; charset=utf-8",
        "Cache-Control": "public, max-age=86400"
      },
      "continue": true
    },
    {
      "src": "/favicon\\.svg",
      "headers": { "Cache-Control": "public, max-age=86400" },
      "continue": true
    },
    {
      "src": "/assets/(.*)",
      "headers": { "Cache-Control": "public, max-age=31536000, immutable" },
      "continue": true
    },
    { "handle": "filesystem" },
    {
      "src": "^/start/talent/?$",
      "dest": "/start/talent.html"
    },
    {
      "src": "^/start/hiring/?$",
      "dest": "/start/hiring.html"
    },
    {
      "src": "^/login/?$",
      "dest": "/login.html"
    },
    {
      "src": "^/signup/?$",
      "dest": "/signup.html"
    },
    {
      "src": "^/privacy/?$",
      "dest": "/privacy.html"
    },
    {
      "src": "^/terms/?$",
      "dest": "/terms.html"
    },
    {
      "src": "^/password-reset/?$",
      "dest": "/password-reset.html"
    },
    {
      "src": "^/careers/urgent-hiring-malaysia-2026/?$",
      "dest": "/careers/urgent-hiring-malaysia-2026.html"
    },
    {
      "src": "^/careers/cadet-pilot-program-malaysia-guide/?$",
      "dest": "/careers/cadet-pilot-program-malaysia-guide.html"
    },
    {
      "src": "^/careers/diamond-grader-vs-gemologist/?$",
      "dest": "/careers/diamond-grader-vs-gemologist.html"
    },
    {
      "src": "^/careers/luxury-retail-jobs-malaysia/?$",
      "dest": "/careers/luxury-retail-jobs-malaysia.html"
    },
    {
      "src": "^/careers/ai-recruitment-explained/?$",
      "dest": "/careers/ai-recruitment-explained.html"
    },
    {
      "src": "^/careers/jewellery-shop-hiring-malaysia/?$",
      "dest": "/careers/jewellery-shop-hiring-malaysia.html"
    },
    {
      "src": "^/careers/?$",
      "dest": "/careers.html"
    },
    {
      "src": "^/jobs/(pilot|cadet-pilot|jeweler|diamond-grader|gemologist|jewelry-designer|luxury-retail|sales-executive|admin-executive|account-assistant|software-developer|graphic-designer|marketing-executive|customer-service|hr-assistant|finance)/?$",
      "dest": "/jobs/$1.html"
    },
    {
      "src": "^/jobs-in-(kuala-lumpur|petaling-jaya|penang|johor-bahru|cyberjaya|shah-alam|subang-jaya)/?$",
      "dest": "/jobs-in-$1.html"
    },
    {
      "src": "^/hire-(pilot|jeweler|diamond-grader|gemologist|sales-team|luxury-retail-staff)/?$",
      "dest": "/hire-$1.html"
    },
    {
      "src": "^/(?:home|login|signup|signout|password-reset|consent|start(?:/[^/]+)?|auth/callback|mfa/(?:challenge|enroll)|onboarding/(?:talent|hm|company(?:/verify)?)|talent(?:/profile)?|hm(?:/post-role|/roles(?:/[^/]+/edit)?)?|hr(?:/invite)?|admin|referrals|points|consult(?:/return)?|feedback/[^/]+|data-requests|privacy|terms|waitlist/confirm|payment/(?:return|mock)|restaurant(?:/.*)?|menu/[^/]+|careers(?:/[^/]+)?|jobs/[^/]+|jobs-in-[^/]+|hire-[^/]+)$",
      "dest": "/index.html"
    },
    { "src": "^/$", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/index.html", "status": 404 }
  ]
}
