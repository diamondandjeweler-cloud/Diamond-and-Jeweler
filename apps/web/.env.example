# ── Supabase ──────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR...

# ── Site ──────────────────────────────────────────────────────────────────────
VITE_SITE_URL=http://localhost:3000

# ── Cloudflare Turnstile (bot protection) ─────────────────────────────────────
# Get from: https://dash.cloudflare.com → Turnstile → Add Site
# REQUIRED in production — without this all sign-ups bypass bot protection
VITE_TURNSTILE_SITE_KEY=0x4AAAAAAA...

# ── Supabase Edge Function secrets (set via: supabase secrets set KEY=value) ──
# These are NOT exposed to the frontend. Set them in Supabase project secrets.

# Resend (email delivery) — https://resend.com/api-keys
RESEND_API_KEY=re_...
# Resend webhook secret — Resend Dashboard → Webhooks → Signing Secret
RESEND_WEBHOOK_SECRET=whsec_...

# Billplz (payments) — https://www.billplz.com/enterprise/developer
BILLPLZ_API_KEY=...
BILLPLZ_COLLECTION_ID=...

# Anthropic (AI matching & BaZi scoring)
ANTHROPIC_API_KEY=sk-ant-...

# Groq (LLM fallback)
GROQ_API_KEY=gsk_...

# Daily.co (video calls) — https://dashboard.daily.co/developers
DAILY_API_KEY=...

# WATI (WhatsApp notifications) — https://app.wati.io/settings/api-access
WATI_API_KEY=...
WATI_API_URL=https://live-mt-server.wati.io/YOUR-INSTANCE
